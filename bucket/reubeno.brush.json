{
    "version": "0.4.0",
    "description": "A bash/POSIX-compatible shell, implemented in Rust.",
    "homepage": "https://brush.sh/",
    "license": "MIT License",
    "pre_install": "$env:CARGO_INSTALL_ROOT = $dir",
    "architecture": {
        "64bit": {
            "url": "https://www.baidu.com/favicon.ico",
            "hash": "skip",
            "installer": {
                "script": "cargo install --locked --root $dir brush-shell"
            }
        }
    },
    "uninstaller": {
        "script": "cargo install --locked --root $dir brush-shell"
    },
    "bin": "bin/brush.exe"
}
